# Copy this file to ".env" (same folder) and fill in your real key.
# Never commit your real .env file to GitHub.

# Get a free token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_hugging_face_token

# Optional: change which free instruction-tuned model is used.
# Examples: mistralai/Mistral-7B-Instruct-v0.3, meta-llama/Llama-3.1-8B-Instruct,
#           HuggingFaceH4/zephyr-7b-beta
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
