# Copy this to .streamlit/secrets.toml for local testing,
# or paste its contents into Streamlit Community Cloud -> App settings -> Secrets.
# Streamlit automatically loads these into os.environ-accessible st.secrets,
# and python-dotenv/os.getenv also works locally via a real .env file.

HF_API_KEY = "your_hugging_face_token"

BACKEND_MODE = "direct"
